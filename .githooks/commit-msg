#!/bin/sh
# ── commit-msg (git provider) ──────────────────────────────────────────────
# Thin git front-end over the shared, provider-neutral rule set so that `git`
# and `jj` enforce identical commit conventions.
#   Required: <type>: <title>   (3-10 imperative words, blank line before body)
#   Shared rules: scripts/hooks/lib/rules.sh
#
# The jj equivalent runs via `jj check` / `jj push` (jj does not fire git hooks).

. "$(git rev-parse --show-toplevel)/scripts/hooks/lib/rules.sh"

rules_validate_message < "$1"
