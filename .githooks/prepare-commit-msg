#!/bin/sh
# ── prepare-commit-msg (git provider) ──────────────────────────────────────
# Injects a commit message template for fresh commits (not merge/amend/squash).
#
# jj equivalent: the `templates.draft_commit_description` config installed by
# scripts/jj-setup.sh pre-fills the `jj describe` editor with the same guide.

COMMIT_MSG_FILE="$1"
COMMIT_SOURCE="$2"   # merge | squash | commit (amend) | empty = new commit

# Only inject for clean new commits
if [ -n "$COMMIT_SOURCE" ]; then
  exit 0
fi

CURRENT_BRANCH=$(git symbolic-ref HEAD 2>/dev/null | sed 's!refs/heads/!!')

# Skip template if message already has content (e.g. -m flag was used)
EXISTING=$(grep -v '^#' "$COMMIT_MSG_FILE" | tr -d '[:space:]')
if [ -n "$EXISTING" ]; then
  exit 0
fi

# Resolve the committer's own GitHub handle at runtime — never hardcode a name,
# and never the literal "@me" (that's a real GitHub account). Falls back to the
# configured git user.name if the GitHub CLI can't answer.
COMMITTER=$(gh api user -q .login 2>/dev/null || true)
[ -n "$COMMITTER" ] || COMMITTER=$(git config user.name 2>/dev/null || echo "your-github-username")

# Detect Claude-Bot branch
if printf '%s' "$CURRENT_BRANCH" | grep -q "^Claude-Bot/"; then
  FOOTER_LINE="Generated by [Claude-Code-Agent] [Claude-Bot] of [@${COMMITTER}]"
else
  FOOTER_LINE="Generated by [<agent-name>-Agent] [Claude-Bot] of [@${COMMITTER}]"
fi

cat > "$COMMIT_MSG_FILE" <<EOF
<type>: <5-8 word imperative title>

# Why this change is needed (3-8 sentences — focus on the problem, not the code):


$FOOTER_LINE

# ─────────────────────────────────────────────────────────────────────────
# COMMIT RULES
# ─────────────────────────────────────────────────────────────────────────
# Type (lowercase): feat  fix  chore  docs  refactor  style  test  lint
# Title:  5-8 words, imperative mood ("add", "fix", "remove", not "added")
# Body:   3-8 sentences explaining WHY — context, problem, impact
# Footer: Generated by [...] line must be present
#
# Branch: $CURRENT_BRANCH
# ─────────────────────────────────────────────────────────────────────────
EOF
