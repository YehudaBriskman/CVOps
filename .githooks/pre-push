#!/bin/sh
# ── pre-push (git provider) ────────────────────────────────────────────────
# Thin git front-end over the shared rule set: validates the branch name and
# blocks pushes to protected branches, then guards against force-pushes.
#   Shared rules: scripts/hooks/lib/rules.sh
#
# The jj equivalent runs via the `jj push` alias (scripts/hooks/jj/pre-push.sh),
# since jj's `jj git push` bypasses this hook entirely.

. "$(git rev-parse --show-toplevel)/scripts/hooks/lib/rules.sh"

CURRENT_BRANCH=$(git symbolic-ref HEAD 2>/dev/null | sed 's!refs/heads/!!')

# Branch name + protected-branch checks (shared with the jj provider). On
# rejection, point at the recovery path so a bad branch isn't a dead end:
# `git open-pr` moves the commits onto a valid feature branch and opens a PR.
if ! rules_validate_branch "$CURRENT_BRANCH"; then
  _rules_box '\033[36m' "recover with one command" \
    "git open-pr -B dev          # moves commits to a feature branch, opens a PR" \
    "" \
    "Auto-derives the branch from your commit; add -c <issue> to link issues," \
    "or -b <Type>/<title> to name it yourself.  See: scripts/open-pr.sh -h"
  exit 1
fi

# ── force-push guard (git-specific — stays in the git hook) ────────────────
while read -r local_ref local_sha remote_ref remote_sha; do
  if [ -n "$remote_sha" ] && [ "$remote_sha" != "0000000000000000000000000000000000000000" ]; then
    if ! git merge-base --is-ancestor "$remote_sha" "$local_sha" 2>/dev/null; then
      _rules_box '\033[31m' "pre-push — force push detected" \
        "Non-fast-forward push rejected on: $remote_ref" \
        "Use --force-with-lease only intentionally; never on shared branches."
      exit 1
    fi
  fi
done

exit 0
