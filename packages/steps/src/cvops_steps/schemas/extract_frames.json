{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Extract Frames Config",
  "type": "object",
  "properties": {
    "interval_seconds": {
      "type": "number", "minimum": 0.1, "default": 2.0,
      "description": "Extract one frame every N seconds"
    },
    "max_frames": {
      "type": "integer", "minimum": 1,
      "description": "Cap on total frames extracted (optional)"
    },
    "dedup_threshold": {
      "type": "number", "minimum": 0.0, "maximum": 1.0, "default": 0.05,
      "description": "Perceptual-hash Hamming distance threshold for near-duplicate suppression"
    }
  },
  "required": ["interval_seconds"],
  "additionalProperties": false
}
