# ── PostgreSQL ───────────────────────────────────────────────────────────
POSTGRES_DB=cvops
POSTGRES_USER=cvops
# Generate with: openssl rand -hex 16
POSTGRES_PASSWORD=

# ── Garage S3 (object store) ─────────────────────────────────────────────
# Garage docs: https://garagehq.deuxfleurs.fr/
# Access key must start with "GK":  echo "GK$(openssl rand -hex 12)"
GARAGE_DEFAULT_ACCESS_KEY=
# Generate with: openssl rand -hex 32
GARAGE_DEFAULT_SECRET_KEY=
GARAGE_DEFAULT_BUCKET=cvops-blobs
# Generate with: openssl rand -hex 32
GARAGE_RPC_SECRET=
# Generate with: openssl rand -hex 32
GARAGE_ADMIN_TOKEN=
# Generate with: openssl rand -hex 32
GARAGE_METRICS_TOKEN=

# ── Redis ────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Auth ─────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
WORKER_TOKEN=

# ── Local dev only ───────────────────────────────────────────────────────
# Set to true to skip startup secret validation (never use in production).
ALLOW_INSECURE_DEFAULTS=false

# ── MLflow tracking ──────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://mlflow:5000
# Browser-side: baked into the frontend bundle at build time (Vite var), so the
# model-page "MLflow run" link resolves. VM devs must set this to their VM host.
VITE_MLFLOW_URL=http://localhost:5000

# ── CVAT (worker-cvat) ───────────────────────────────────────────────────
CVAT_HOST=localhost
CVAT_USERNAME=admin
# Generate with: openssl rand -hex 16
CVAT_PASSWORD=
# Shared secret CVAT signs review-completion webhooks with (HMAC-SHA256).
# Generate with: openssl rand -hex 32
CVAT_WEBHOOK_SECRET=
CVAT_PUBLIC_URL=http://localhost:8080

# ── API internal ─────────────────────────────────────────────────────────
# Derived from above — used in docker-compose
DATABASE_URL=postgresql+asyncpg://cvops:${POSTGRES_PASSWORD}@postgres:5432/cvops
S3_ENDPOINT=http://garage:3900
S3_ACCESS_KEY=${GARAGE_DEFAULT_ACCESS_KEY}
S3_SECRET_KEY=${GARAGE_DEFAULT_SECRET_KEY}
S3_BUCKET=${GARAGE_DEFAULT_BUCKET}
S3_REGION=garage

# ── Observability (--profile observability) ──────────────────────────────
# Generate with: openssl rand -hex 16
GRAFANA_ADMIN_PASSWORD=
POSTGRES_EXPORTER_DSN=postgresql://cvops:${POSTGRES_PASSWORD}@postgres:5432/cvops?sslmode=disable
REDIS_EXPORTER_ADDR=redis://redis:6379
