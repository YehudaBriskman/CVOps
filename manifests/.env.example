# ── PostgreSQL ───────────────────────────────────────────────────────────
POSTGRES_DB=cvops
POSTGRES_USER=cvops
POSTGRES_PASSWORD=change_me_postgres

# ── Garage S3 (object store) ─────────────────────────────────────────────
# Garage docs: https://garagehq.deuxfleurs.fr/
# Access key must start with "GK". Generate with:
#   echo "GK$(openssl rand -hex 12)"
#   openssl rand -hex 32   # for secrets/tokens below
GARAGE_DEFAULT_ACCESS_KEY=GKchange_me_access_key
GARAGE_DEFAULT_SECRET_KEY=change_me_secret_key
GARAGE_DEFAULT_BUCKET=cvops-blobs
GARAGE_RPC_SECRET=change_me_rpc_secret_hex_32_bytes
GARAGE_ADMIN_TOKEN=change_me_admin_token
GARAGE_METRICS_TOKEN=change_me_metrics_token

# ── Redis ────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Auth ─────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change_me_jwt_secret_min_32_chars_required
WORKER_TOKEN=change_me_worker_token

# ── MLflow tracking ──────────────────────────────────────────────────────
# Executor-side: train.py forwards this into the trainer subprocess so runs
# log to the tracking server (compose-internal DNS).
MLFLOW_TRACKING_URI=http://mlflow:5000
# Browser-side: baked into the frontend bundle at build time (Vite var), so the
# model-page "MLflow run" link resolves. Unlike the S3 presign host (derived
# per-request from the Host header), this can't be set per-request — VM devs
# must set it to their VM host, e.g. http://my-dev-vm:5000.
VITE_MLFLOW_URL=http://localhost:5000

# ── CVAT (worker-cvat) ───────────────────────────────────────────────────
# Host/IP of the CVAT server — used by worker-cvat to list/deploy models.
# Tiltfile auto-prepends http:// and :8080 if not present.
CVAT_HOST=localhost
CVAT_USERNAME=admin
CVAT_PASSWORD=change_me_cvat
# Shared secret CVAT signs review-completion webhooks with (HMAC-SHA256). The
# API verifies it; worker-cvat registers webhooks with it. Must match on both.
CVAT_WEBHOOK_SECRET=change_me_cvat_webhook_secret
# Browser-reachable CVAT base for "Open in CVAT" links (worker-cvat builds them).
CVAT_PUBLIC_URL=http://localhost:8080

# ── API internal ─────────────────────────────────────────────────────────
# Derived from above — used in docker-compose
DATABASE_URL=postgresql+asyncpg://cvops:change_me_postgres@postgres:5432/cvops
S3_ENDPOINT=http://garage:3900
S3_ACCESS_KEY=${GARAGE_DEFAULT_ACCESS_KEY}
S3_SECRET_KEY=${GARAGE_DEFAULT_SECRET_KEY}
S3_BUCKET=${GARAGE_DEFAULT_BUCKET}
S3_REGION=garage

# ── Observability (--profile observability) ──────────────────────────────
# Logs + infra metrics stack (Loki/Promtail/Prometheus/Grafana + exporters).
# Brought up with `docker compose --profile observability up -d`; not in Tilt.
# Grafana admin login (user: admin) at http://localhost:3001.
GRAFANA_ADMIN_PASSWORD=change_me_grafana
# postgres-exporter DSN — must match POSTGRES_* above (sslmode=disable: in-cluster).
POSTGRES_EXPORTER_DSN=postgresql://cvops:change_me_postgres@postgres:5432/cvops?sslmode=disable
# redis-exporter target.
REDIS_EXPORTER_ADDR=redis://redis:6379
