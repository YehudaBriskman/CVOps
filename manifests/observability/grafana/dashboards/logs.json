{
  "id": null,
  "uid": "cvops-logs",
  "title": "CVOps · Logs (Loki)",
  "tags": ["cvops", "logs", "loki"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "compose_service",
        "type": "query",
        "datasource": { "type": "loki", "uid": "loki" },
        "query": { "label": "compose_service", "stream": "", "type": 1 },
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "logs",
      "title": "Container logs · service=$compose_service",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 20, "w": 24, "x": 0, "y": 0 },
      "options": {
        "showTime": true,
        "wrapLogMessage": true,
        "enableLogDetails": true,
        "dedupStrategy": "none",
        "sortOrder": "Descending"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "{compose_service=~\"$compose_service\"}"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Log volume by service",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 20 },
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "bars", "stacking": { "mode": "normal" } } } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum by (compose_service) (count_over_time({compose_service=~\"$compose_service\"}[1m]))",
          "legendFormat": "{{compose_service}}"
        }
      ]
    }
  ]
}
