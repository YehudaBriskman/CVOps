{
  "id": null,
  "uid": "cvops-postgres",
  "title": "CVOps · PostgreSQL",
  "tags": ["cvops", "postgres"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Up",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "pg_up" }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Active connections",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 18, "x": 6, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (datname) (pg_stat_activity_count{datname!~\"template.*|postgres\"})",
          "legendFormat": "{{datname}}"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Commits / Rollbacks per second",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 9 },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(pg_stat_database_xact_commit{datname!~\"template.*\"}[5m]))",
          "legendFormat": "commits"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(pg_stat_database_xact_rollback{datname!~\"template.*\"}[5m]))",
          "legendFormat": "rollbacks"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Tuples returned / fetched per second",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 9 },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(pg_stat_database_tup_returned{datname!~\"template.*\"}[5m]))",
          "legendFormat": "returned"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(pg_stat_database_tup_fetched{datname!~\"template.*\"}[5m]))",
          "legendFormat": "fetched"
        }
      ]
    }
  ]
}
