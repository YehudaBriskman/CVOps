# ── PostgreSQL ───────────────────────────────────────────────────────────
POSTGRES_DB=cvops
POSTGRES_USER=cvops
POSTGRES_PASSWORD=change_me_postgres

# ── MinIO ────────────────────────────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change_me_minio
MINIO_BUCKET=cvops-blobs

# ── Redis ────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Auth ─────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change_me_jwt_secret_min_32_chars_required
WORKER_TOKEN=change_me_worker_token

# ── CVAT (Phase 2) ───────────────────────────────────────────────────────
CVAT_URL=http://cvat:8080
CVAT_USERNAME=admin
CVAT_PASSWORD=change_me_cvat

# ── API internal ─────────────────────────────────────────────────────────
# Derived from above — used in docker-compose
DATABASE_URL=postgresql+asyncpg://cvops:change_me_postgres@postgres:5432/cvops
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=change_me_minio
